<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><title>XPigeon Photos</title>
<style>
 :root{--r:#d40000;--bg:#f2f2f2;--bd:#e0e0e0}
 body{font-family:Arial,sans-serif;margin:0;background:var(--bg);height:100vh;display:flex;flex-direction:column;overflow:hidden}
 header{background:#1a1a1a;padding:10px 20px;color:#fff;display:flex;justify-content:space-between;align-items:center;border-bottom:3px solid var(--r);flex-shrink:0}
 .logo{font-size:24px;font-weight:800;text-decoration:none;color:#fff}.logo span{color:var(--r)}
 .btn{background:var(--r);color:#fff;padding:6px 15px;text-decoration:none;font-weight:700;font-size:12px;border-radius:2px}
 .area{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;align-items:center}
 main{width:100%;max-width:1000px;background:#fff;border:1px solid var(--bd);padding:20px;box-sizing:border-box}
 .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
 .v{text-align:center}.thumb{width:100%;aspect-ratio:16/9;background:#111;overflow:hidden;display:flex;border:1px solid #eee}
 .thumb img{width:100%;height:100%;object-fit:cover}.v-t{display:block;margin-top:8px;font-weight:700;font-size:14px;color:#0070bb}
 footer{margin-top:40px;padding:20px;text-align:center;border-top:1px solid #eee;width:100%}
 .ad{background:#fff;border:1px solid #ddd;display:inline-block;width:728px;height:90px}
 .ad img{width:100%;height:100%;object-fit:cover}.tag{font-size:9px;color:#bbb;margin-bottom:5px;display:block}
 .back{display:inline-block;margin-bottom:15px;color:#666;text-decoration:none;font-size:12px;font-weight:700}
</style>
</head>
<body>
<header>
 <a href="https://xpigeon.uk" class="logo"><span>X</span>PIGEON PICS</a>
 <a href="https://xpigeon.uk" class="btn">BACK TO VIDEOS</a>
</header>
<div class="area">
 <main>
  <a href="https://xpigeon.uk" class="back">← BACK TO XPIGEON.UK</a>
  <h2 style="text-transform:uppercase;font-size:18px;border-bottom:1px solid #eee;padding-bottom:10px">HOT! Pigeon Pics</h2>
  <div id="g" class="grid"></div>
  <footer>
   <span class="tag">AD</span>
   <a href="#" class="ad"><img src="https://via.placeholder.com/728x90?text=Ad" alt="Ad"></a>
  </footer>
 </main>
</div>
<script>
const PH=[{t:"Rock Dove On Wire",url:"https://upload.wikimedia.org/wikipedia/commons/b/bf/Rock_Dove_perched_on_wire.jpg"},{t:"Hot Pigeon Summer",url:"https://upload.wikimedia.org/wikipedia/commons/6/62/Ringeltaube_%28April_2025%29.jpg"},{t:"Mature Pigeon Perch",url:"https://upload.wikimedia.org/wikipedia/commons/2/2a/Streptopelia_decaocto_Kiev.JPG"},{t:"Three Pigeons Naughty",url:"https://upload.wikimedia.org/wikipedia/commons/d/dc/Columba_livia_Sopot_Poland.jpg"},{t:"Young Step-Pigeons",url:"https://upload.wikimedia.org/wikipedia/commons/2/2b/Two_Rock_Pigeon_Preening_Each_Other_042620231.jpg"},{t:"Pigeon In Prison",url:"https://upload.wikimedia.org/wikipedia/commons/5/5f/Homing_pigeon_2.jpg"},{t:"Summer Pigeons",url:"https://upload.wikimedia.org/wikipedia/commons/9/90/Pigeons%2C_bonding.jpg"},{t:"Tajik Pigeons",url:"https://upload.wikimedia.org/wikipedia/commons/2/2d/%D0%93%D1%83%D0%BB%D0%B0%D0%B1%D0%B8_Columbidae.jpg"},{t:"Hot Pigeon Roof",url:"https://upload.wikimedia.org/wikipedia/commons/3/3d/Postduif.jpg"}];
const g=document.getElementById('g');
PH.forEach(p=>{g.innerHTML+=`<div class="v"><div class="thumb"><img src="${p.url}" alt="${p.t}" onerror="this.src='https://via.placeholder.com/400x225?text=Error'"></div><span class="v-t">${p.t}</span></div>`});
</script>
</body>
</html>
